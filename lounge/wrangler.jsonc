{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lounge-worker",
  "main": "worker.js",
  "compatibility_date": "2025-01-01",

  // Durable Object binding
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOM",
        "class_name": "Room"
      }
    ]
  },

  // 初回デプロイ用 migration（SQLite storage backend）
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Room"]
    }
  ]
}
